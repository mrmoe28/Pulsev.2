{
  "name": "pulsecrm",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.4.2",
  "description": "Modern React-based CRM dashboard for crew management with intelligent interfaces and advanced collaboration tools",
  "engines": {
    "node": ">=20.17.0"
  },
  "scripts": {
    "build": "cd apps/web && npm install --legacy-peer-deps && npm run build",
    "dev": "cd apps/web && npm run dev",
    "lint": "cd apps/web && npm run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "rm -rf node_modules apps/web/node_modules",
    "prepare": "husky install",
    "install-deps": "cd apps/web && npm install --legacy-peer-deps"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "eslint": "^8.56.0",
    "husky": "^8.0.3",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100
  }
}
