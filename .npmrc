# NPM Configuration for Pulse CRM
# Ensures consistent package manager behavior across environments

# Use npm registry
registry=https://registry.npmjs.org/

# Disable package-lock generation in subdirectories (use workspace root)
package-lock=true

# Enable strict SSL
strict-ssl=true

# Save exact versions
save-exact=true

# Disable automatic dependency updates
save-prefix=""

# Use npm for all package management (no corepack)
engine-strict=true

# Performance optimizations
prefer-offline=true
audit-level=moderate

# Workspace configuration
workspaces-update=true

# Disable telemetry
fund=false
audit=false
