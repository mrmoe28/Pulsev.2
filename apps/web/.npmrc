# Force npm usage for Vercel deployment
# Prevent pnpm auto-detection

registry=https://registry.npmjs.org/
package-lock=true
package-lock-only=false
save-exact=false
audit=false
fund=false
prefer-offline=true
engine-strict=true

# Disable alternative package managers
pnpm=false
yarn=false

# npm specific settings
user-agent=npm
